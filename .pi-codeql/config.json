{
  "codeqlBin": "codeql",
  "queryPacks": {
    "javascript-typescript": [
      "codeql/javascript-queries"
    ],
    "csharp": [
      "codeql/csharp-queries"
    ],
    "python": [
      "codeql/python-queries"
    ],
    "go": [
      "codeql/go-queries"
    ],
    "java-kotlin": [
      "codeql/java-queries"
    ]
  },
  "buildCommands": {},
  "autoUpdatePacks": true,
  "defaultSuite": "code-scanning",
  "severityThreshold": "warning",
  "pathsIgnore": [
    "node_modules",
    "dist",
    "build",
    "bin",
    "obj",
    ".git",
    ".next",
    "out"
  ],
  "updatePacksTimeoutMs": 180000,
  "scanTimeoutMs": 600000,
  "initTimeoutMs": 900000
}
